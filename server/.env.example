# Server port
PORT=4000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/guardianeye?retryWrites=true&w=majority

# AI Service URL (local — not deployed)
AI_SERVICE_URL=http://localhost:5001

# Deployed frontend URL (your Vercel URL)
CLIENT_URL=https://your-app-name.vercel.app

# File & frame settings
MAX_FILE_SIZE_MB=20
FRAME_SAMPLE_INTERVAL=5
